# Image and host binding
API_IMAGE=ghcr.io/OWNER/REPOSITORY/api:staging
API_HOST_BIND=127.0.0.1
# Host-side port for nginx or another external ingress. The API container listens on internal port 3000.
API_HOST_PORT=3000

# Application runtime
NODE_ENV=development
# Must match the POSTGRES_* values below. POSTGRES_* initializes the database container; DATABASE_URL connects API and migrations.
DATABASE_URL=postgresql://gitiempo:change-me@postgres:5432/gitiempo
ALLOWED_ORIGINS=https://gitiempo.itsua.dev,https://gitiempo-admin.itsua.dev
LOG_LEVEL=info
LOG_EXTENDED=false
SWAGGER_ENABLED=true
SWAGGER_PATH=docs

# PostgreSQL service
POSTGRES_DB=gitiempo
POSTGRES_USER=gitiempo
POSTGRES_PASSWORD=change-me

# Seed users. Firebase Auth users must already exist with these UIDs.
SEED_ADMIN_EMAIL=gitiempo@itsua.com
SEED_ADMIN_FIREBASE_UID=5EU7Psf9HfeBoyq9qb91fHhj5jg2
SEED_MEMBER_EMAIL=gitiempo-member@itsua.com
SEED_MEMBER_FIREBASE_UID=QsYJofDbGJOdCqt3toLCVH3HJX63

# Firebase Admin
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CLIENT_EMAIL=firebase-admin@example.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# JWT
JWT_ACCESS_SECRET=replace-with-at-least-32-characters
JWT_REFRESH_SECRET=replace-with-at-least-32-characters
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d
JWT_ISSUER=gitiempo-api
JWT_AUDIENCE=gitiempo-clients

# GitHub App integration
GITHUB_APP_ID=
GITHUB_APP_CLIENT_ID=
GITHUB_APP_CLIENT_SECRET=

# Token encryption
ENCRYPTION_KEY=

# Application URLs
APP_URL=https://gitiempo-api.itsua.dev
USER_SPA_URL=https://gitiempo.itsua.dev
ADMIN_SPA_URL=https://gitiempo-admin.itsua.dev

# Email delivery
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=noreply@example.com
INVITES_EMAIL_CONSOLE_FALLBACK=true
