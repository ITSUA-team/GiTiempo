# GitHub Environment: staging
# Safe placeholders only. Configure real values in GitHub Environment variables
# and secrets; do not copy this file into a committed real environment file.

# Frontend deployment variables
CLOUDFLARE_ACCOUNT_ID=
VITE_API_BASE_URL=https://gitiempo-api.itsua.dev
VITE_ADMIN_APP_URL=https://gitiempo-admin.itsua.dev
VITE_USER_APP_URL=https://gitiempo.itsua.dev
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=

# API deployment variables
PUBLIC_API_URL=https://gitiempo-api.itsua.dev
API_DEPLOY_PATH=/root/gitiempo
VPS_HOST=
VPS_USER=

# GitHub Environment secrets
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=
VPS_SSH_KEY=

# VPS prerequisite for private API images:
# Docker on the VPS must already be logged into ghcr.io with read access to
# ghcr.io/<owner>/<repo>/api, unless the API package is public.
