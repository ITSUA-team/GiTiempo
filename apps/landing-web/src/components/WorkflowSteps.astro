---
import { workflowSteps } from '../data/content';
---

<section id="how-it-works" class="bg-landing-dark py-10 text-text-inverse sm:min-h-[760px] sm:py-12 lg:py-24">
  <div class="page-shell">
    <div class="flex flex-col gap-7 lg:flex-row lg:items-end lg:justify-between">
      <div class="max-w-xl">
        <p class="eyebrow text-landing-purple-light">HOW IT WORKS</p>
        <h2 class="section-heading mt-4 text-text-inverse">One connected flow, not three separate tools.</h2>
      </div>
      <p class="max-w-sm text-[15px] leading-6 text-landing-muted-inverse sm:text-base">
        Work starts in an issue, becomes an accurate time entry, and ends up ready for review.
      </p>
    </div>
    <ol class="mt-8 border-y border-white/20 lg:border-0 lg:mt-12 lg:grid lg:grid-cols-3">
      {
        workflowSteps.map((step, index) => (
          <li class:list={[
            'flex min-h-[188px] flex-col justify-center gap-3 py-4 sm:min-h-0 sm:flex-row sm:items-center sm:gap-6 sm:py-[18px] lg:min-h-72 lg:flex-col lg:items-stretch lg:justify-between lg:p-7',
            index < workflowSteps.length - 1 && 'border-b border-white/20 lg:border-b-0 lg:border-r',
          ]}>
            <p class="shrink-0 font-mono text-[13px] font-bold text-landing-purple-light">{step.number}</p>
            <div class="lg:mt-10">
              <h3 class="text-xl font-bold tracking-[-0.03em] lg:hidden">{step.compactTitle}</h3>
              <h3 class="hidden text-xl font-bold tracking-[-0.03em] lg:block">{step.title}</h3>
              <p class="mt-3 text-sm leading-6 text-landing-muted-inverse lg:hidden">{step.compactBody}</p>
              <p class="mt-3 hidden text-sm leading-6 text-landing-muted-inverse lg:block">{step.body}</p>
              <p class="mt-5 hidden text-xs font-semibold text-landing-purple-light lg:block">{step.detail}</p>
            </div>
            <span class="mt-8 hidden text-3xl text-landing-purple-light lg:block" aria-hidden="true">{index === workflowSteps.length - 1 ? '✓' : '→'}</span>
          </li>
        ))
      }
    </ol>
  </div>
</section>
