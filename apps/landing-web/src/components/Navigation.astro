---
import { navigation } from '../data/content';

interface Props {
  userAppUrl: string;
}

const { userAppUrl } = Astro.props;
---

<header class="sticky top-0 z-40 border-b border-white/10 bg-landing-dark/95 backdrop-blur lg:absolute lg:inset-x-0 lg:border-0 lg:bg-transparent lg:backdrop-blur-none">
  <div class="page-shell flex min-h-16 flex-wrap items-center justify-between gap-x-5 py-3 lg:min-h-0 lg:py-0 lg:pt-8">
    <a class="inline-flex min-h-7 items-center gap-2.5 text-lg font-bold tracking-[-0.03em] text-text-inverse" href="/">
      <span class="grid size-7 place-items-center rounded-[6px] bg-brand text-base leading-none" aria-hidden="true">G</span>
      <span>GITiempo</span>
    </a>
    <a class="action-nav order-2 px-4 py-2 text-[13px] sm:order-3" href={userAppUrl}>
      Start tracking
    </a>
    <nav class="order-3 w-full border-t border-white/10 pt-2 sm:order-2 sm:w-auto sm:border-0 sm:pt-0" aria-label="Main navigation">
      <ul class="flex items-center justify-between gap-3 sm:justify-center sm:gap-7">
        {
          navigation.map((item) => (
            <li>
              <a class="inline-flex min-h-8 items-center text-xs font-medium text-landing-muted-inverse transition-colors hover:text-text-inverse sm:text-sm" href={item.href}>
                {item.label}
              </a>
            </li>
          ))
        }
      </ul>
    </nav>
  </div>
</header>
