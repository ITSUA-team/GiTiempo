# =============================================================================
# GI Tiempo API — Environment Variables
# Copy this file to .env and fill in the values
# =============================================================================

# --- Application ---
PORT=3000
NODE_ENV=development

# --- Database ---
DATABASE_URL=postgresql://user:password@localhost:5432/gi_tiempo

# --- CORS ---
# Comma-separated list of allowed origins. Leave empty to disable CORS.
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174

# --- Logging ---
# One of: fatal, error, warn, info, debug, trace, silent
LOG_LEVEL=info
# Set to true to log full req/res details (headers, body, etc.)
LOG_EXTENDED=false

# --- Swagger / OpenAPI ---
SWAGGER_ENABLED=true
SWAGGER_PATH=docs

# --- Firebase Auth ---
FIREBASE_PROJECT_ID=
FIREBASE_PRIVATE_KEY=
FIREBASE_CLIENT_EMAIL=

# --- GitHub App (User-to-Server Integration) ---
GITHUB_APP_ID=
GITHUB_APP_CLIENT_ID=
GITHUB_APP_CLIENT_SECRET=

# --- Security ---
SESSION_SECRET=
ENCRYPTION_KEY=

# --- Application URLs ---
APP_URL=http://localhost:3000
USER_SPA_URL=http://localhost:5173
ADMIN_SPA_URL=http://localhost:5174

# --- Email (SMTP) ---
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=noreply@example.com
