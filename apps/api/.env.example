# =============================================================================
# GI Tiempo API — Environment Variables
# Copy this file to .env and fill in the values
# =============================================================================

# --- Database ---
DATABASE_URL=postgresql://user:password@localhost:5432/gi_tiempo

# --- Firebase Auth ---
FIREBASE_PROJECT_ID=
FIREBASE_PRIVATE_KEY=
FIREBASE_CLIENT_EMAIL=

# --- GitHub App (User-to-Server Integration) ---
GITHUB_APP_ID=
GITHUB_APP_CLIENT_ID=
GITHUB_APP_CLIENT_SECRET=

# --- Security ---
SESSION_SECRET=
ENCRYPTION_KEY=

# --- Application URLs ---
APP_URL=http://localhost:3000
USER_SPA_URL=http://localhost:5173
ADMIN_SPA_URL=http://localhost:5174

# --- Email (SMTP) ---
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=noreply@example.com
