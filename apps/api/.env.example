# --- Application ---
PORT=3000
NODE_ENV=development

# --- Database ---
DATABASE_URL=postgresql://user:password@localhost:5432/gi_tiempo

# --- Seed users ---
# Optional. Firebase Auth users must already exist with these UIDs.
SEED_ADMIN_EMAIL=
SEED_ADMIN_FIREBASE_UID=
SEED_MEMBER_EMAIL=
SEED_MEMBER_FIREBASE_UID=

# --- CORS ---
# Comma-separated list of allowed origins. Leave empty to disable CORS.
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174

# --- Logging ---
# One of: fatal, error, warn, info, debug, trace, silent
LOG_LEVEL=info
# Set to true to log full req/res details (headers, body, etc.)
LOG_EXTENDED=false

# --- Swagger / OpenAPI ---
SWAGGER_ENABLED=true
SWAGGER_PATH=docs

# --- Firebase Auth ---
FIREBASE_PROJECT_ID=
FIREBASE_PRIVATE_KEY=
FIREBASE_CLIENT_EMAIL=

# --- GitHub App (User-to-Server Integration) ---
# Required in production. Optional in development/test; GitHub endpoints return a
# controlled config error when used without these values.
GITHUB_APP_ID=
GITHUB_APP_CLIENT_ID=
GITHUB_APP_CLIENT_SECRET=

# --- JWT (local access + refresh token secrets) ---
# Generate with: `openssl rand -base64 48`. Must be at least 32 characters.
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=
# Access token TTL (short-lived); any ms-compatible duration string.
JWT_ACCESS_TTL=15m
# Refresh token TTL (long-lived).
JWT_REFRESH_TTL=7d
JWT_ISSUER=gitiempo-api
JWT_AUDIENCE=gitiempo-clients

# --- Security ---
SESSION_SECRET=
# Base64-encoded 32-byte key for AES-256-GCM. Generate with:
# `openssl rand -base64 32`. Required in production.
ENCRYPTION_KEY=

# --- Application URLs ---
# APP_URL is used to build the GitHub OAuth callback URL.
APP_URL=http://localhost:3000
# GitHub OAuth callbacks always redirect to USER_SPA_URL/profile.
USER_SPA_URL=http://localhost:5173
ADMIN_SPA_URL=http://localhost:5174

# --- Email (SMTP) ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=notify@itsua.com
SMTP_PASSWORD=
EMAIL_FROM=noreply@example.com
# Invite email delivery: set to true to log invite URLs to console instead of SMTP.
# Ignored (forced false) when NODE_ENV=production to prevent token leaks.
INVITES_EMAIL_CONSOLE_FALLBACK=false
