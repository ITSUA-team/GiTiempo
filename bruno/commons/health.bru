meta {
  name: Health Check
  type: http
  seq: 1
}

get {
  url: {{baseUrl}}/commons/health
  body: none
  auth: none
}

tests {
  test("status is 200", function() {
    expect(res.status).to.equal(200);
  });

  test("status is ok", function() {
    expect(res.body.status).to.equal("ok");
  });

  test("db is connected", function() {
    expect(res.body.db).to.equal("connected");
  });
}
