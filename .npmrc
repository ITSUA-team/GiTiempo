# Wait 7 days (10080 minutes) before allowing newly published packages.
# Protects against supply-chain attacks on freshly published packages.
minimum-release-age=10080

# Strict peer dependencies
strict-peer-dependencies=true

# Avoid auto-install repair loops before every run in restricted/offline environments.
verify-deps-before-run=warn

# Monorepo settings
shamefully-hoist=false
node-linker=hoisted
